PORT=3000
NODE_ENV=development

# Database (PostgreSQL via Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/naissancechain?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT Auth
JWT_SECRET="super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# AES Encryption Key (32 bytes hex)
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Blockchain (Ethers.js)
BLOCKCHAIN_RPC_URL="http://127.0.0.1:8545" # Hardhat local
PRIVATE_KEY="0x..." # Backend wallet private key
CONTRACT_ADDRESS="0x..."

# IPFS (Pinata)
PINATA_API_KEY=""
PINATA_SECRET_API_KEY=""

# Twilio (SMS / WhatsApp)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
