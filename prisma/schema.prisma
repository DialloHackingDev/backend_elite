generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Notification {
  id        String   @id @default(uuid())
  citizenId String
  title     String
  content   String
  type      String
  relatedId String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  citizen   Citizen  @relation(fields: [citizenId], references: [id])

  @@index([citizenId])
}

model Agent {
  id                   String    @id @default(uuid())
  nationalAgentId      String    @unique
  firstName            String
  lastName             String
  role                 Role      @default(AGENT)
  status               Status    @default(ACTIVE)
  prefectureAssignment String
  passwordHash         String
  twoFactorSecret      String?
  twoFactorEnabled     Boolean   @default(false)
  lastLogin            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  births               Birth[]
  requests             Request[]
}

model Establishment {
  id            String  @id @default(uuid())
  code          String  @unique
  name          String
  type          String
  prefecture    String
  subPrefecture String
  latitude      Float?
  longitude     Float?
  births        Birth[]
}

model Birth {
  id                 String           @id @default(uuid())
  nationalId         String           @unique
  blockchainHash     String?          @unique
  ipfsCid            String?
  status             String           @default("PENDING_SYNC")
  childFirstName     String
  childLastName      String
  childGender        String
  dateOfBirth        DateTime
  timeOfBirth        String?
  placeOfBirth       String
  motherFullName     String
  motherDob          DateTime
  motherCni          String?
  motherPrefecture   String
  fatherFullName     String?
  fatherDob          DateTime?
  fatherCni          String?
  agentId            String
  establishmentId    String
  gpsCoordinates     String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  isLateRegistration Boolean          @default(false)
  validationStatus   ValidationStatus @default(APPROVED)
  witness1Cni        String?
  witness1FullName   String?
  witness2Cni        String?
  witness2FullName   String?
  localId            String?          @unique
  agent              Agent            @relation(fields: [agentId], references: [id])
  establishment      Establishment    @relation(fields: [establishmentId], references: [id])
  request            Request?
  verifications      Verification[]

  @@index([nationalId])
  @@index([status])
  @@index([createdAt])
  @@index([validationStatus])
}

model Verification {
  id           String   @id @default(uuid())
  birthId      String
  verifiedAt   DateTime @default(now())
  ipAddress    String?
  verifierType String
  result       String
  birth        Birth    @relation(fields: [birthId], references: [id])
}

model Citizen {
  id            String         @id @default(uuid())
  fullName      String
  phoneNumber   String         @unique
  passwordHash  String
  cniNumber     String         @unique
  prefecture    String         @default("Conakry")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  notifications Notification[]
  requests      Request[]

  @@index([phoneNumber])
  @@index([cniNumber])
}

model Request {
  id                 String        @id @default(uuid())
  citizenId          String
  type               RequestType
  status             RequestStatus @default(PENDING)
  birthId            String?       @unique
  deliveryMethod     String        @default("DIGITAL")
  phoneNumber        String?
  email              String?
  address            String?
  documents          String?
  notes              String?
  processedAt        DateTime?
  processedBy        String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  assignedAgentId    String?
  birthDate          DateTime?
  childFirstName     String?
  childGender        String?
  childLastName      String?
  fatherCni          String?
  fatherDob          DateTime?
  fatherFullName     String?
  isLateRegistration Boolean       @default(false)
  motherCni          String?
  motherDob          DateTime?
  motherFullName     String?
  motherPrefecture   String?
  placeOfBirth       String?
  timeOfBirth        String?
  witness1Cni        String?
  witness1FullName   String?
  witness2Cni        String?
  witness2FullName   String?
  agent              Agent?        @relation(fields: [assignedAgentId], references: [id])
  birth              Birth?        @relation(fields: [birthId], references: [id])
  citizen            Citizen       @relation(fields: [citizenId], references: [id])

  @@index([citizenId])
  @@index([status])
  @@index([createdAt])
}

enum Role {
  AGENT
  ADMIN
  MINISTRY
  JUSTICE
  CITIZEN
}

enum Status {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ValidationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
}

enum RequestType {
  BIRTH_CERTIFICATE
  COPY_CERTIFICATE
  CORRECTION
}
